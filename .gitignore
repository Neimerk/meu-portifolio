# --- DEPENDÊNCIAS ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/cache
!.yarn/versions

# --- BUILD E OUTPUT ---
.next/
out/
build/
dist/
/.vercel

# --- SEGURANÇA (MUITO IMPORTANTE) ---
# Ignora todas as variáveis de ambiente para não vazar chaves de API/Senhas
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# --- DEBUG E LOGS ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# --- TESTES ---
coverage/
.nyc_output

# --- SISTEMA E EDITORES ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.bak

# --- TYPESCRIPT ---
*.tsbuildinfo
# NOTA: Não ignore o 'next-env.d.ts' se estiver usando TypeScript, 
# pois ele é gerado pelo Next.js para garantir a tipagem correta do projeto.